@using FacturationApp.Components.Layout

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
                <NotAuthorized Context="authState">
                    @if (authState.User.Identity?.IsAuthenticated == true)
                    {
                        <AccessDenied />
                    }
                    else
                    {
                        <RedirectToLogin />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Page introuvable</PageTitle>
            <LayoutView Layout="typeof(MainLayout)">
                <div class="container mt-5 text-center">
                    <h1 class="display-4">404</h1>
                    <p class="lead">La page demandee est introuvable.</p>
                    <a href="/" class="btn btn-primary">Retour a l'accueil</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
