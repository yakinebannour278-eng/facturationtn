@* Shared reusable confirmation modal *@

@if (Visible)
{
    <div class="modal-overlay">
        <div class="modal-box" style="max-width:440px;text-align:center">
            <div style="font-size:2.75rem;margin-bottom:.5rem">@Icon</div>
            <h5 style="margin-bottom:.75rem">@Title</h5>
            <p style="color:var(--text-muted);margin-bottom:1.5rem">@Message</p>
            <div style="display:flex;gap:.75rem;justify-content:center">
                <button class="btn btn-outline" @onclick="OnCancel">@CancelLabel</button>
                <button class="btn @ConfirmClass" @onclick="OnConfirm">@ConfirmLabel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Confirmer";
    [Parameter] public string Message { get; set; } = "Êtes-vous sûr ?";
    [Parameter] public string Icon { get; set; } = "⚠️";
    [Parameter] public string ConfirmLabel { get; set; } = "Confirmer";
    [Parameter] public string CancelLabel { get; set; } = "Annuler";
    [Parameter] public string ConfirmClass { get; set; } = "btn-danger";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
