@page "/produits"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IProduitService ProduitService
@using FacturationApp.Models
@using FacturationApp.Services

<PageTitle>Produits | FacturaTN</PageTitle>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <div class="page-title">Gestion des Produits &amp; Services</div>
            <div class="page-subtitle">@produits.Count produit(s) trouvé(s)</div>
        </div>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <button class="btn btn-primary" @onclick="NouveauProduit">Nouveau Produit</button>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
}

<!-- Filtres -->
<div class="filters-bar">
    <input class="form-control" placeholder="Reference, designation, categorie..."
           @bind="search" @oninput="OnSearchInput" />
    <select class="form-control" @bind="filtreTVA" @bind:after="Rechercher">
        <option value="">Tous les taux TVA</option>
        <option value="0">0% — Exonéré</option>
        <option value="7">7% — Réduit</option>
        <option value="13">13% — Intermédiaire</option>
        <option value="19">19% — Normal</option>
    </select>
    <select class="form-control" @bind="filtreActif" @bind:after="Rechercher">
        <option value="true">Actifs</option>
        <option value="false">Inactifs</option>
        <option value="">Tous</option>
    </select>
    <button class="btn btn-outline" @onclick="ResetFiltres">Reinitialiser</button>
</div>

<LoadingSpinner IsLoading="@isLoading" />

@if (!isLoading)
{
    <div class="card">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Référence</th>
                        <th>Désignation</th>
                        <th>Catégorie</th>
                        <th style="text-align:right">Prix HT (DT)</th>
                        <th style="text-align:center">Taux TVA</th>
                        <th style="text-align:right">Prix TTC (DT)</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!produits.Any())
                    {
                        <tr>
                            <td colspan="8" style="text-align:center;color:var(--text-muted);padding:2.5rem">
                                Aucun produit trouvé.
                            </td>
                        </tr>
                    }
                    @foreach (var p in produits)
                    {
                        <tr>
                            <td><span class="badge badge-primary">@p.Reference</span></td>
                            <td>
                                <strong>@p.Designation</strong>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div style="font-size:.75rem;color:var(--text-muted)">@p.Description</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.Categorie))
                                { <span class="badge badge-secondary">@p.Categorie</span> }
                            </td>
                            <td style="text-align:right;font-weight:600">@p.PrixUnitaireHT.ToString("N3")</td>
                            <td style="text-align:center"><span class="tva-badge">@p.TauxTVA%</span></td>
                            <td style="text-align:right;font-weight:700;color:var(--primary)">
                                @((p.PrixUnitaireHT * (1 + p.TauxTVA / 100m)).ToString("N3"))
                            </td>
                            <td>
                                @if (p.Actif)
                                { <span class="badge badge-success">Actif</span> }
                                else
                                { <span class="badge badge-danger">Inactif</span> }
                            </td>
                            <td style="white-space:nowrap">
                                <AuthorizeView Roles="Admin">
                                    <Authorized>
                                        <button class="btn btn-sm btn-outline" @onclick="() => Modifier(p)">Editer</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => produitASupprimer = p">Suppr</button>
                                    </Authorized>
                                    <NotAuthorized>
                                        <span style="color:var(--text-muted);font-size:.8rem">Lecture seule</span>
                                    </NotAuthorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal formulaire -->
@if (showForm)
{
    <div class="modal-overlay" @onclick="FermerModal">
        <div class="modal-box" @onclick:stopPropagation>
            <h5 style="margin-bottom:1.5rem;font-size:1.1rem;font-weight:700">
                @(editingProduit.Id == 0 ? "Nouveau Produit" : "Modifier Produit")
            </h5>
            <EditForm Model="editingProduit" OnValidSubmit="Sauvegarder">
                <DataAnnotationsValidator />
                <div class="row">
                    <div class="col">
                        <div class="form-group">
                            <label class="form-label">Référence *</label>
                            <InputText class="form-control" @bind-Value="editingProduit.Reference" placeholder="INF-001" />
                            <ValidationMessage For="() => editingProduit.Reference" class="validation-message" />
                        </div>
                    </div>
                    <div class="col">
                        <div class="form-group">
                            <label class="form-label">Catégorie</label>
                            <InputText class="form-control" @bind-Value="editingProduit.Categorie" placeholder="Informatique, Service..." />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Désignation *</label>
                    <InputText class="form-control" @bind-Value="editingProduit.Designation"
                               placeholder="Nom du produit ou service" />
                    <ValidationMessage For="() => editingProduit.Designation" class="validation-message" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" @bind-Value="editingProduit.Description"
                                   rows="2" placeholder="Description détaillée (optionnel)" />
                </div>
                <div class="row">
                    <div class="col">
                        <div class="form-group">
                            <label class="form-label">Prix Unitaire HT (DT) *</label>
                            <InputNumber class="form-control" @bind-Value="editingProduit.PrixUnitaireHT" />
                            <ValidationMessage For="() => editingProduit.PrixUnitaireHT" class="validation-message" />
                        </div>
                    </div>
                    <div class="col">
                        <div class="form-group">
                            <label class="form-label">Taux TVA * (Tunisie)</label>
                            <InputSelect class="form-control" @bind-Value="editingProduit.TauxTVA">
                                <option value="0">0% — Exonéré (médical, agriculture...)</option>
                                <option value="7">7% — Réduit (alimentaire...)</option>
                                <option value="13">13% — Intermédiaire</option>
                                <option value="19">19% — Normal (standard)</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
                @if (editingProduit.PrixUnitaireHT > 0)
                {
                    <div style="padding:.75rem;background:var(--primary-light);border-radius:6px;margin-bottom:1rem;font-size:.85rem">
                        Prix TTC calculé :
                        <strong style="color:var(--primary)">
                            @((editingProduit.PrixUnitaireHT * (1 + editingProduit.TauxTVA / 100m)).ToString("N3")) DT
                        </strong>
                        (HT @editingProduit.PrixUnitaireHT.ToString("N3") +
                        TVA @((editingProduit.PrixUnitaireHT * editingProduit.TauxTVA / 100m).ToString("N3")) DT)
                    </div>
                }
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
                        <InputCheckbox @bind-Value="editingProduit.Actif" />
                        <span>Produit actif (disponible à la facturation)</span>
                    </label>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border)">
                    <button type="button" class="btn btn-outline" @onclick="FermerModal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Sauvegarder</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<ConfirmDialog
    Visible="@(produitASupprimer != null)"
    Title="Désactiver le produit ?"
    Message="@($"Désactiver '{produitASupprimer?.Designation}' ? Il ne sera plus proposé lors de la création de factures.")"
    ConfirmLabel="Désactiver"
    OnConfirm="SupprimerConfirme"
    OnCancel="() => produitASupprimer = null" />

@code {
    private List<Produit> produits = new();
    private Produit editingProduit = new();
    private Produit? produitASupprimer;
    private bool showForm = false;
    private bool isLoading = true;
    private string search = "";
    private string filtreTVA = "";
    private string filtreActif = "true";
    private string message = "";
    private bool isError = false;
    private System.Timers.Timer? debounceTimer;

    protected override async Task OnInitializedAsync() => await Rechercher();

    private void OnSearchInput(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";
        debounceTimer?.Stop();
        debounceTimer = new System.Timers.Timer(350);
        debounceTimer.Elapsed += async (s, ev) =>
        {
            debounceTimer?.Stop();
            await InvokeAsync(async () => { await Rechercher(); StateHasChanged(); });
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task Rechercher()
    {
        isLoading = true;
        decimal? taux = decimal.TryParse(filtreTVA, out var t) ? t : null;
        bool? actif = filtreActif switch { "true" => true, "false" => false, _ => null };
        produits = await ProduitService.GetAllAsync(search, taux, actif);
        isLoading = false;
    }

    private void NouveauProduit()
    {
        editingProduit = new Produit { TauxTVA = 19m, Actif = true };
        showForm = true;
    }

    private void Modifier(Produit p)
    {
        editingProduit = new Produit
        {
            Id = p.Id, Reference = p.Reference, Designation = p.Designation,
            Description = p.Description, PrixUnitaireHT = p.PrixUnitaireHT,
            TauxTVA = p.TauxTVA, Categorie = p.Categorie, Actif = p.Actif
        };
        showForm = true;
    }

    private void FermerModal() => showForm = false;

    private async Task Sauvegarder()
    {
        try
        {
            if (editingProduit.Id == 0)
                await ProduitService.CreateAsync(editingProduit);
            else
                await ProduitService.UpdateAsync(editingProduit);

            message = "Produit sauvegardé.";
            isError = false;
            showForm = false;
            await Rechercher();
        }
        catch (Exception ex)
        {
            message = $"Erreur : {ex.Message}";
            isError = true;
        }
    }

    private async Task SupprimerConfirme()
    {
        if (produitASupprimer == null) return;
        await ProduitService.DeleteAsync(produitASupprimer.Id);
        message = $"Produit '{produitASupprimer.Designation}' désactivé.";
        produitASupprimer = null;
        await Rechercher();
    }

    private async Task ResetFiltres()
    {
        search = ""; filtreTVA = ""; filtreActif = "true";
        await Rechercher();
    }
}
