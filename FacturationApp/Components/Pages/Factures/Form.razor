@page "/factures/nouvelle"
@page "/factures/{Id:int}/modifier"
@rendermode InteractiveServer
@inject IFactureService FactureService
@inject IClientService ClientService
@inject IProduitService ProduitService
@inject NavigationManager Nav
@using FacturationApp.Models
@using FacturationApp.Services

<PageTitle>@(Id == null ? "Nouvelle Facture" : "Modifier Facture") | FacturaTN</PageTitle>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div class="page-title">@(Id == null ? "Nouvelle Facture" : "Modifier Facture")</div>
        <button class="btn btn-outline" @onclick='() => Nav.NavigateTo("/factures")'>← Retour</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(erreur))
{
    <div class="alert alert-danger">@erreur</div>
}

@if (isLoading)
{
    <LoadingSpinner IsLoading="true" Message="Chargement..." />
}
else
{
<div class="row">
    <!-- LEFT: facture metadata -->
    <div style="flex:0 0 360px; padding:0 .5rem">
        <div class="card">
            <div class="card-title" style="margin-bottom:1rem">Informations Facture</div>

            <div class="form-group">
                <label class="form-label">Numéro</label>
                <input class="form-control" value="@facture.Numero" disabled style="background:var(--surface-2);color:var(--text-muted)" />
            </div>

            <div class="form-group">
                <label class="form-label">Client *</label>
                <select class="form-control" @bind="facture.ClientId">
                    <option value="0">-- Sélectionner un client --</option>
                    @foreach (var c in clients)
                    {
                        <option value="@c.Id">@c.Nom @c.Prenom — @c.Ville</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Date Facture *</label>
                <input type="date" class="form-control" @bind="facture.DateFacture" />
            </div>

            <div class="form-group">
                <label class="form-label">Date Échéance</label>
                <input type="date" class="form-control" @bind="facture.DateEcheance" />
            </div>

            <div class="form-group">
                <label class="form-label">Statut</label>
                <select class="form-control" @bind="facture.Statut">
                    <option value="0">Brouillon</option>
                    <option value="1">Emise</option>
                    <option value="2">Payee</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Timbre Fiscal (DT) *</label>
                <input type="number" class="form-control" step="0.001" min="0"
                       @bind="facture.MontantTimbre" @bind:after="RecalculerTotaux" />
                <small style="color:var(--text-muted);font-size:.75rem">Timbre fiscal tunisien (configurable dans Paramètres)</small>
            </div>

            <div class="form-group">
                <label class="form-label">Notes / Observations</label>
                <textarea class="form-control" rows="3" @bind="facture.Notes"
                          placeholder="Conditions de paiement, remarques..."></textarea>
            </div>
        </div>

        <!-- Récapitulatif -->
        <div class="card">
            <div class="card-title" style="margin-bottom:1rem">Recapitulatif</div>
            <table style="width:100%;border-collapse:collapse">
                <tr>
                    <td style="padding:.4rem 0;color:var(--text-muted)">Total HT</td>
                    <td style="text-align:right;font-weight:600">@totalHT.ToString("N3") DT</td>
                </tr>
                @foreach (var kvp in tvaParTaux.OrderBy(x => x.Key))
                {
                    <tr>
                        <td style="padding:.4rem 0;color:var(--text-muted)">TVA @kvp.Key%</td>
                        <td style="text-align:right">@kvp.Value.ToString("N3") DT</td>
                    </tr>
                }
                <tr>
                    <td style="padding:.4rem 0;color:var(--text-muted)">Total TVA</td>
                    <td style="text-align:right;font-weight:600">@totalTVA.ToString("N3") DT</td>
                </tr>
                <tr>
                    <td style="padding:.4rem 0;color:var(--text-muted)">Timbre Fiscal</td>
                    <td style="text-align:right">@facture.MontantTimbre.ToString("N3") DT</td>
                </tr>
                <tr style="border-top:2px solid var(--primary);margin-top:.5rem">
                    <td style="padding:.7rem 0 0;font-weight:800;font-size:1.05rem">TOTAL TTC</td>
                    <td style="padding:.7rem 0 0;text-align:right;font-weight:800;font-size:1.05rem;color:var(--primary)">
                        @totalTTC.ToString("N3") DT
                    </td>
                </tr>
            </table>

            <div style="margin-top:1.25rem;display:flex;gap:.5rem">
                <button class="btn btn-outline" style="flex:1" @onclick='() => Nav.NavigateTo("/factures")'>
                    Annuler
                </button>
                <button class="btn btn-primary" style="flex:1" @onclick="Sauvegarder" disabled="@isSaving">
                    @(isSaving ? "Sauvegarde..." : "Sauvegarder")
                </button>
            </div>
        </div>
    </div>

    <!-- RIGHT: lignes -->
    <div style="flex:1; padding:0 .5rem; min-width:0">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Lignes de Facture (@facture.Lignes.Count ligne(s))</div>
                <button class="btn btn-success btn-sm" @onclick="AjouterLigne">Ajouter une ligne</button>
            </div>

            @if (!facture.Lignes.Any())
            {
                <div style="text-align:center;color:var(--text-muted);padding:3rem 1rem">
                    <div style="font-size:2rem;margin-bottom:.5rem">-</div>
                    <div>Aucune ligne. Cliquez sur <strong>Ajouter une ligne</strong> pour commencer.</div>
                </div>
            }

            @for (int i = 0; i < facture.Lignes.Count; i++)
            {
                int idx = i;
                var ligne = facture.Lignes[idx];
                <div style="border:1px solid var(--border);border-radius:8px;padding:1rem;margin-bottom:.75rem;background:var(--surface-2)">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem">
                        <span style="font-size:.8rem;font-weight:600;color:var(--text-muted)">Ligne @(idx + 1)</span>
                        <button class="btn btn-sm btn-danger" @onclick="() => SupprimerLigne(idx)">Supprimer</button>
                    </div>
                    <div class="row" style="gap:.5rem 0">
                        <!-- Produit selector -->
                        <div style="flex:0 0 260px;padding:0 .4rem">
                            <label class="form-label" style="font-size:.72rem">Produit</label>
                            <select class="form-control" value="@ligne.ProduitId"
                                    @onchange="e => OnProduitChange(idx, e)">
                                <option value="0">-- Choisir un produit --</option>
                                @foreach (var p in produitsActifs)
                                {
                                    <option value="@p.Id">[@p.Reference] @p.Designation</option>
                                }
                            </select>
                        </div>
                        <!-- Désignation -->
                        <div style="flex:1;padding:0 .4rem">
                            <label class="form-label" style="font-size:.72rem">Désignation</label>
                            <input class="form-control" placeholder="Description de la prestation..."
                                   @bind="ligne.Designation" @bind:after="RecalculerTotaux" />
                        </div>
                        <!-- Quantité -->
                        <div style="flex:0 0 80px;padding:0 .4rem">
                            <label class="form-label" style="font-size:.72rem">Quantité</label>
                            <input type="number" class="form-control" min="1"
                                   @bind="ligne.Quantite" @bind:after="RecalculerTotaux" />
                        </div>
                        <!-- Prix unitaire HT -->
                        <div style="flex:0 0 130px;padding:0 .4rem">
                            <label class="form-label" style="font-size:.72rem">Prix U. HT (DT)</label>
                            <input type="number" class="form-control" step="0.001" min="0"
                                   @bind="ligne.PrixUnitaireHT" @bind:after="RecalculerTotaux" />
                        </div>
                        <!-- Taux TVA -->
                        <div style="flex:0 0 90px;padding:0 .4rem">
                            <label class="form-label" style="font-size:.72rem">TVA %</label>
                            <select class="form-control" @bind="ligne.TauxTVA" @bind:after="RecalculerTotaux">
                                <option value="0">0%</option>
                                <option value="7">7%</option>
                                <option value="13">13%</option>
                                <option value="19">19%</option>
                            </select>
                        </div>
                        <!-- Montant ligne -->
                        <div style="flex:0 0 130px;padding:0 .4rem;display:flex;flex-direction:column;justify-content:flex-end">
                            <label class="form-label" style="font-size:.72rem">Montant TTC</label>
                            <div style="padding:.5rem .75rem;background:var(--primary-light);border-radius:6px;font-weight:700;color:var(--primary)">
                                @((ligne.Quantite * ligne.PrixUnitaireHT * (1 + ligne.TauxTVA / 100m)).ToString("N3")) DT
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private Facture facture = new();
    private List<Client> clients = new();
    private List<Produit> produitsActifs = new();
    private string erreur = "";
    private bool isSaving = false;
    private bool isLoading = true;

    private decimal totalHT;
    private decimal totalTVA;
    private decimal totalTTC;
    private Dictionary<decimal, decimal> tvaParTaux = new();

    protected override async Task OnInitializedAsync()
    {
        clients = await ClientService.GetAllAsync(actif: true);
        produitsActifs = await ProduitService.GetAllAsync(actif: true);

        if (Id.HasValue)
        {
            var existing = await FactureService.GetByIdAsync(Id.Value);
            if (existing != null)
                facture = existing;
            else
            {
                erreur = "Facture introuvable.";
                Nav.NavigateTo("/factures");
            }
        }
        else
        {
            decimal timbre = await FactureService.GetTimbreDefautAsync();
            facture = new Facture
            {
                Numero = await FactureService.GenererNumeroAsync(),
                DateFacture = DateTime.Today,
                DateEcheance = DateTime.Today.AddDays(30),
                MontantTimbre = timbre
            };
        }

        RecalculerTotaux();
        isLoading = false;
    }

    private void AjouterLigne()
    {
        facture.Lignes.Add(new LigneFacture { TauxTVA = 19m, Quantite = 1 });
        RecalculerTotaux();
    }

    private void SupprimerLigne(int index)
    {
        facture.Lignes.RemoveAt(index);
        RecalculerTotaux();
    }

    private void OnProduitChange(int idx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int produitId))
        {
            facture.Lignes[idx].ProduitId = produitId;
            var produit = produitsActifs.FirstOrDefault(p => p.Id == produitId);
            if (produit != null)
            {
                facture.Lignes[idx].Designation = produit.Designation;
                facture.Lignes[idx].PrixUnitaireHT = produit.PrixUnitaireHT;
                facture.Lignes[idx].TauxTVA = produit.TauxTVA;
            }
            RecalculerTotaux();
        }
    }

    private void RecalculerTotaux()
    {
        totalHT = facture.Lignes.Sum(l => l.Quantite * l.PrixUnitaireHT);
        tvaParTaux = facture.Lignes
            .GroupBy(l => l.TauxTVA)
            .ToDictionary(g => g.Key, g => g.Sum(l => l.Quantite * l.PrixUnitaireHT * l.TauxTVA / 100m));
        totalTVA = tvaParTaux.Values.Sum();
        totalTTC = totalHT + totalTVA + facture.MontantTimbre;
    }

    private async Task Sauvegarder()
    {
        erreur = "";
        if (facture.ClientId == 0) { erreur = "Veuillez sélectionner un client."; return; }
        if (!facture.Lignes.Any()) { erreur = "La facture doit contenir au moins une ligne."; return; }
        if (facture.Lignes.Any(l => l.ProduitId == 0)) { erreur = "Veuillez sélectionner un produit pour chaque ligne."; return; }
        if (facture.Lignes.Any(l => l.Quantite < 1)) { erreur = "La quantité doit être au minimum 1."; return; }
        if (facture.Lignes.Any(l => l.PrixUnitaireHT < 0)) { erreur = "Le prix unitaire ne peut pas être négatif."; return; }

        isSaving = true;
        try
        {
            facture.TotalHT  = totalHT;
            facture.TotalTVA = totalTVA;
            facture.TotalTTC = totalTTC;

            if (Id.HasValue)
                await FactureService.UpdateAsync(facture);
            else
                await FactureService.CreateAsync(facture);

            Nav.NavigateTo("/factures");
        }
        catch (Exception ex)
        {
            erreur = $"Erreur lors de la sauvegarde : {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
