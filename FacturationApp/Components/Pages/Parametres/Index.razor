@page "/parametres"
@rendermode InteractiveServer
@inject IParametreService ParametreService
@using FacturationApp.Models
@using FacturationApp.Services

<PageTitle>Paramètres | FacturaTN</PageTitle>

<div class="page-header">
    <div class="page-title">Parametres de l'Application</div>
    <div class="page-subtitle">Configuration générale, fiscale et de facturation</div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
}

@if (parametres.Count == 0)
{
    <p style="color:var(--text-muted)">Chargement...</p>
}
else
{
    @foreach (var groupe in parametres.GroupBy(p => p.Categorie).OrderBy(g => g.Key))
    {
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    @(groupe.Key switch {
                        "Fiscal" => "Parametres Fiscaux",
                        "Société" => "Informations Societe",
                        "Facturation" => "Facturation",
                        _ => groupe.Key
                    })
                </div>
            </div>
            <table style="width:100%">
                <thead>
                    <tr>
                        <th style="width:200px">Paramètre</th>
                        <th>Description</th>
                        <th style="width:350px">Valeur</th>
                        <th style="width:80px">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in groupe)
                    {
                        <tr>
                            <td><code style="font-size:.75rem;color:var(--primary)">@p.Cle</code></td>
                            <td style="color:var(--text-muted);font-size:.85rem">@p.Description</td>
                            <td>
                                @if (p.Cle == "FACTURE_MENTIONS_LEGALES")
                                {
                                    <textarea class="form-control" rows="3" @bind="p.Valeur" style="font-size:.8rem"></textarea>
                                }
                                else
                                {
                                    <input class="form-control" @bind="p.Valeur" />
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary" @onclick="() => SauvegarderParam(p)">Sauver</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div style="display:flex;justify-content:flex-end;margin-top:1rem">
        <button class="btn btn-primary" @onclick="SauvegarderTout">Sauvegarder tout</button>
    </div>
}

<!-- Info box -->
<div class="card" style="border-left:4px solid var(--info);background:var(--surface-2)">
    <div style="font-weight:600;margin-bottom:.5rem">A propos des parametres</div>
    <ul style="margin:0;padding-left:1.25rem;font-size:.875rem;color:var(--text-muted)">
        <li><strong>TIMBRE_MONTANT_DEFAUT</strong> : Valeur pré-remplie lors de la création d'une facture. Modifiable par facture.</li>
        <li><strong>SOCIETE_*</strong> : Informations affichées sur les factures imprimées.</li>
        <li><strong>FACTURE_DELAI_PAIEMENT</strong> : Nombre de jours ajoutés à la date de facture pour l'échéance.</li>
    </ul>
</div>

@code {
    private List<Parametre> parametres = new();
    private string message = "";
    private bool isError = false;

    protected override async Task OnInitializedAsync()
    {
        parametres = await ParametreService.GetAllAsync();
    }

    private async Task SauvegarderParam(Parametre p)
    {
        try
        {
            await ParametreService.SetAsync(p.Cle, p.Valeur);
            message = $"Paramètre '{p.Cle}' sauvegardé.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Erreur : {ex.Message}";
            isError = true;
        }
    }

    private async Task SauvegarderTout()
    {
        try
        {
            foreach (var p in parametres)
                await ParametreService.SetAsync(p.Cle, p.Valeur);
            message = "Tous les paramètres ont été sauvegardés.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Erreur : {ex.Message}";
            isError = true;
        }
    }
}
