@page "/"
@rendermode InteractiveServer
@inject IDashboardService DashboardService

<PageTitle>Dashboard Ventes | FacturaTN</PageTitle>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <div class="page-title">Vue d'ensemble des Ventes</div>
            <div class="page-subtitle">Chiffre d'affaires et performance commerciale</div>
        </div>
        <select class="form-control" style="max-width:110px" @bind="annee" @bind:after="ChargerDonnees">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
            { <option value="@y">@y</option> }
        </select>
    </div>
</div>

<LoadingSpinner IsLoading="@isLoading" Message="Chargement..." />

@if (!isLoading && kpi != null)
{
    <!-- BENTO ROW 1: 4 gradient cards -->
    <div class="bento">
        <div class="bento-3">
            <div class="gcard gcard-pink">
                <div class="gcard-icon">HT</div>
                <div class="gcard-label">CA Total HT</div>
                <div class="gcard-value">@kpi.TotalHTAnnee.ToString("N0")</div>
                <div class="gcard-sub">Dinars Tunisiens</div>
                <div class="gcard-pill">@annee</div>
                <div class="gcard-sparkline"><svg viewBox="0 0 200 48" preserveAspectRatio="none"><polyline points="0,40 30,30 60,35 90,20 120,25 150,10 200,15" fill="none" stroke="white" stroke-width="2"/></svg></div>
            </div>
        </div>
        <div class="bento-3">
            <div class="gcard gcard-purple">
                <div class="gcard-icon">TC</div>
                <div class="gcard-label">CA Total TTC</div>
                <div class="gcard-value">@kpi.TotalTTCAnnee.ToString("N0")</div>
                <div class="gcard-sub">Toutes taxes comprises</div>
                <div class="gcard-pill">@annee</div>
                <div class="gcard-sparkline"><svg viewBox="0 0 200 48" preserveAspectRatio="none"><polyline points="0,38 40,28 70,32 100,18 140,22 170,8 200,12" fill="none" stroke="white" stroke-width="2"/></svg></div>
            </div>
        </div>
        <div class="bento-3">
            <div class="gcard gcard-teal">
                <div class="gcard-icon">TVA</div>
                <div class="gcard-label">TVA Collectée</div>
                <div class="gcard-value">@kpi.TotalTVAAnnee.ToString("N0")</div>
                <div class="gcard-sub">DT — total TVA</div>
                <div class="gcard-pill">@annee</div>
                <div class="gcard-sparkline"><svg viewBox="0 0 200 48" preserveAspectRatio="none"><polyline points="0,42 50,32 90,36 130,20 160,24 200,14" fill="none" stroke="white" stroke-width="2"/></svg></div>
            </div>
        </div>
        <div class="bento-3">
            <div class="gcard gcard-amber">
                <div class="gcard-icon">NF</div>
                <div class="gcard-label">Factures Émises</div>
                <div class="gcard-value">@kpi.NbFactures</div>
                <div class="gcard-sub">factures non annulées</div>
                <div class="gcard-pill">@kpi.NbClients clients actifs</div>
                <div class="gcard-sparkline"><svg viewBox="0 0 200 48" preserveAspectRatio="none"><polyline points="0,44 60,34 100,38 140,24 180,20 200,16" fill="none" stroke="white" stroke-width="2"/></svg></div>
            </div>
        </div>
    </div>

    <!-- BENTO ROW 2: Bar chart (8 cols) + mini stats (4 cols) -->
    <div class="bento">
        <div class="bento-8">
            <div class="card" style="height:100%;margin-bottom:0">
                <div class="card-header">
                    <div class="card-title">Évolution mensuelle du CA — @annee</div>
                    <span style="font-size:11px;color:var(--text-muted)">Montants TTC en DT</span>
                </div>
                @{ var maxV = caParMois.Any() ? (double)caParMois.Max(m => m.TotalTTC) : 1.0; if(maxV==0) maxV=1; }
                @if (caParMois.Any())
                {
                    <div class="chart-bars">
                        @foreach (var m in caParMois)
                        {
                            var pct = (double)m.TotalTTC / maxV * 100;
                            <div class="chart-bar-col">
                                <div class="chart-bar-val">@m.TotalTTC.ToString("N0")</div>
                                <div class="chart-bar-fill" style="height:@(pct)%"></div>
                                <div class="chart-bar-label">@m.Periode</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="text-align:center;color:var(--text-muted);padding:3rem">Aucune donnée pour @annee.</p>
                }
            </div>
        </div>
        <div class="bento-4">
            <div style="display:flex;flex-direction:column;gap:14px;height:100%">
                <div class="card" style="flex:1;margin-bottom:0">
                    <div class="kpi-label">Produits actifs</div>
                    <div style="font-size:36px;font-weight:800;color:var(--purple);line-height:1;margin:6px 0">@kpi.NbProduits</div>
                    <div style="font-size:12px;color:var(--text-muted)">dans le catalogue</div>
                </div>
                <div class="card" style="flex:1;margin-bottom:0">
                    <div class="kpi-label">Clients actifs</div>
                    <div style="font-size:36px;font-weight:800;color:var(--pink);line-height:1;margin:6px 0">@kpi.NbClients</div>
                    <div style="font-size:12px;color:var(--text-muted)">dans le système</div>
                </div>
                <div class="card" style="flex:1;margin-bottom:0;background:linear-gradient(135deg,#f5f0ff,#ede9fe)">
                    <div class="kpi-label">Timbres fiscaux</div>
                    <div style="font-size:24px;font-weight:800;color:var(--purple);line-height:1;margin:6px 0">@kpi.TotalTimbres.ToString("N3")</div>
                    <div style="font-size:12px;color:var(--text-muted)">DT collectés</div>
                </div>
            </div>
        </div>
    </div>

    <!-- BENTO ROW 3: Top Clients (6) + Top Produits (6) -->
    <div class="bento">
        <div class="bento-6">
            <div class="card" style="margin-bottom:0">
                <div class="card-header">
                    <div class="card-title">🏆 Top Clients</div>
                    <span class="badge badge-primary">par CA TTC</span>
                </div>
                @{ var maxC = caParClient.Any() ? (double)caParClient.Max(x => x.TotalTTC) : 1.0; if(maxC==0)maxC=1; }
                @if (caParClient.Any())
                {
                    <table>
                        <thead><tr><th>Client</th><th style="text-align:right">HT</th><th style="text-align:right">TTC</th><th style="text-align:center">Fac.</th></tr></thead>
                        <tbody>
                            @foreach (var c in caParClient.Take(5))
                            {
                                var pct = (double)c.TotalTTC / maxC * 100;
                                <tr>
                                    <td>
                                        <div style="font-weight:600">@c.NomClient</div>
                                        <div class="mini-progress"><div class="mini-progress-fill" style="width:@(pct)%;background:var(--purple)"></div></div>
                                    </td>
                                    <td style="text-align:right;font-size:12px;color:var(--text-muted)">@c.TotalHT.ToString("N0")</td>
                                    <td style="text-align:right;font-weight:700;color:var(--purple)">@c.TotalTTC.ToString("N0")</td>
                                    <td style="text-align:center"><span class="badge badge-primary">@c.NbFactures</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p style="color:var(--text-muted);text-align:center;padding:2rem">Aucune donnée.</p> }
            </div>
        </div>
        <div class="bento-6">
            <div class="card" style="margin-bottom:0">
                <div class="card-header">
                    <div class="card-title">📦 Top Produits</div>
                    <span class="badge badge-success">par CA HT</span>
                </div>
                @{ var maxP = caParProduit.Any() ? (double)caParProduit.Max(x => x.TotalHT) : 1.0; if(maxP==0)maxP=1; }
                @if (caParProduit.Any())
                {
                    <table>
                        <thead><tr><th>Produit</th><th style="text-align:center">Qté</th><th style="text-align:right">CA HT</th></tr></thead>
                        <tbody>
                            @foreach (var p in caParProduit.Take(5))
                            {
                                var pct = (double)p.TotalHT / maxP * 100;
                                <tr>
                                    <td>
                                        <div style="font-weight:600">@p.Designation</div>
                                        <div class="mini-progress"><div class="mini-progress-fill" style="width:@(pct)%;background:#0d9488"></div></div>
                                    </td>
                                    <td style="text-align:center"><span class="badge badge-secondary">@p.Quantite</span></td>
                                    <td style="text-align:right;font-weight:700;color:#0d9488">@p.TotalHT.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <p style="color:var(--text-muted);text-align:center;padding:2rem">Aucune donnée.</p> }
            </div>
        </div>
    </div>
}

@code {
    private DashboardKpi? kpi;
    private List<ChiffreAffaireParPeriode> caParMois = new();
    private List<ChiffreAffaireParClient> caParClient = new();
    private List<ChiffreAffaireParProduit> caParProduit = new();
    private int annee = DateTime.Now.Year;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() => await ChargerDonnees();

    private async Task ChargerDonnees()
    {
        isLoading = true;
        kpi          = await DashboardService.GetKpisAsync(annee);
        caParMois    = await DashboardService.GetCAParMoisAsync(annee);
        caParClient  = await DashboardService.GetCAParClientAsync();
        caParProduit = await DashboardService.GetCAParProduitAsync();
        isLoading    = false;
    }
}


