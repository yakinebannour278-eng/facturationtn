@page "/"
@rendermode InteractiveServer
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <div>
        <h2>Sales and tax dashboard</h2>
        <p>Track Tunisian VAT, the tax stamp, and revenue trends from a single screen.</p>
    </div>

    <div class="filters">
        <label>
            From
            <input type="date" @bind="FromDate" />
        </label>
        <label>
            To
            <input type="date" @bind="ToDate" />
        </label>
        <label>
            Period
            <select @bind="Grouping">
                <option>Daily</option>
                <option selected>Monthly</option>
                <option>Yearly</option>
            </select>
        </label>
        <button class="btn btn-primary" @onclick="RefreshAsync">Refresh</button>
    </div>
</div>

@if (_summary is null)
{
    <div class="loading-state">Loading dashboard...</div>
}
else
{
    <section class="metric-grid">
        <article class="metric-card">
            <span>Total revenue pre-tax</span>
            <strong>@Money(_summary.TotalRevenuePreTax)</strong>
        </article>
        <article class="metric-card">
            <span>Total revenue post-tax</span>
            <strong>@Money(_summary.TotalRevenuePostTax)</strong>
        </article>
        <article class="metric-card">
            <span>Total VAT collected</span>
            <strong>@Money(_summary.TotalVatCollected)</strong>
        </article>
        <article class="metric-card">
            <span>Tax stamp collected</span>
            <strong>@Money(_summary.TotalTaxStampCollected)</strong>
        </article>
    </section>

    <section class="content-grid">
        <div class="panel">
            <h3>VAT by rate</h3>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Rate</th>
                        <th>Total VAT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vat in _summary.VatByRate)
                    {
                        <tr>
                            <td>@Rate(vat.VatRate)</td>
                            <td>@Money(vat.TotalVat)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h3>Revenue by period</h3>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Period</th>
                        <th>Pre-tax</th>
                        <th>Post-tax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _summary.RevenueByPeriod)
                    {
                        <tr>
                            <td>@item.Label</td>
                            <td>@Money(item.PreTax)</td>
                            <td>@Money(item.PostTax)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="content-grid">
        <div class="panel">
            <h3>Top customers</h3>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Pre-tax</th>
                        <th>Post-tax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _summary.TopCustomers)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@Money(item.PreTax)</td>
                            <td>@Money(item.PostTax)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h3>Top products</h3>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Pre-tax</th>
                        <th>Post-tax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _summary.TopProducts)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@Money(item.PreTax)</td>
                            <td>@Money(item.PostTax)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private DashboardSummary? _summary;
    private DateTime FromDate { get; set; } = new(DateTime.Today.Year, 1, 1);
    private DateTime ToDate { get; set; } = DateTime.Today;
    private string Grouping { get; set; } = "Monthly";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _summary = await DashboardService.GetSummaryAsync(FromDate, ToDate, Grouping);
    }

    private static string Money(decimal value) => value.ToString("N3");

    private static string Rate(decimal value) => $"{decimal.Round(value * 100m, 0)}%";
}
