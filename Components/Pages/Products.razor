@page "/products"
@page "/"
@rendermode InteractiveServer
@using InvoiceApp.Models
@using InvoiceApp.Services
@inject IProductService ProductService

<PageTitle>Products</PageTitle>

<h1>Products</h1>

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ShowCreateForm">Add Product</button>

    @if (isEditing)
    {
        <div class="card p-3 mb-4">
            <h4>@(currentProduct.Id == 0 ? "Add Product" : "Edit Product")</h4>
            <EditForm Model="@currentProduct" OnValidSubmit="SaveProduct">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText @bind-Value="currentProduct.Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Unit Price (Pre-Tax)</label>
                    <InputNumber @bind-Value="currentProduct.UnitPricePreTax" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">VAT Rate (%)</label>
                    <InputNumber @bind-Value="currentProduct.VatRate" class="form-control" />
                </div>
                <div class="mb-3 form-check">
                    <InputCheckbox @bind-Value="currentProduct.IsActive" class="form-check-input" id="isActiveCheck" />
                    <label class="form-check-label" for="isActiveCheck">Is Active</label>
                </div>
                <button type="submit" class="btn btn-success">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
            </EditForm>
        </div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price (Pre-tax)</th>
                <th>VAT Rate</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.UnitPricePreTax.ToString("C")</td>
                    <td>@p.VatRate%</td>
                    <td>@(p.IsActive ? "Yes" : "No")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(p)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(p)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Product>? products;
    private Product currentProduct = new() { IsActive = true };
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        products = await ProductService.GetAllAsync();
    }

    private void ShowCreateForm()
    {
        currentProduct = new Product { IsActive = true };
        isEditing = true;
    }

    private void EditProduct(Product p)
    {
        currentProduct = new Product
        {
            Id = p.Id,
            Name = p.Name,
            UnitPricePreTax = p.UnitPricePreTax,
            VatRate = p.VatRate,
            IsActive = p.IsActive
        };
        isEditing = true;
    }

    private async Task SaveProduct()
    {
        if (currentProduct.Id == 0)
        {
            await ProductService.CreateAsync(currentProduct);
        }
        else
        {
            await ProductService.UpdateAsync(currentProduct);
        }
        
        isEditing = false;
        await LoadProducts();
    }

    private async Task DeleteProduct(Product p)
    {
        await ProductService.DeleteAsync(p.Id);
        await LoadProducts();
    }

    private void CancelEdit()
    {
        isEditing = false;
    }
}
