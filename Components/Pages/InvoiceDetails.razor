@page "/invoices/{Id:int}"
@rendermode InteractiveServer
@using InvoiceApp.Models
@using InvoiceApp.Services
@inject IInvoiceService InvoiceService
@inject NavigationManager NavigationManager

<PageTitle>Invoice Details</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (invoice == null)
{
    <div class="alert alert-danger">Invoice not found.</div>
    <button class="btn btn-secondary" @onclick="GoBack">Back to Invoices</button>
}
else
{
    <div class="container mt-4">
        <div class="row align-items-center mb-4">
            <div class="col-sm-6">
                <h2 class="mb-0">Invoice #@invoice.InvoiceNumber</h2>
                <div class="text-muted">Issued on @invoice.IssueDate.ToShortDateString()</div>
            </div>
            <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
                <button class="btn btn-outline-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to Invoices
                </button>
                <button class="btn btn-primary ms-2" onclick="window.print()">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body bg-light rounded">
                        <h5 class="card-title text-uppercase text-muted fs-6 mb-3">Billed To</h5>
                        @if (invoice.Customer != null)
                        {
                            <h4 class="mb-1">@invoice.Customer.Name</h4>
                            <p class="mb-0 text-secondary">
                                ID: @invoice.Customer.Id<br />
                                Tax ID: @(string.IsNullOrEmpty(invoice.Customer.TaxId) ? "N/A" : invoice.Customer.TaxId)
                            </p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6 mt-3 mt-md-0">
                <div class="card h-100 shadow-sm border-0 text-md-end">
                    <div class="card-body rounded" style="background-color: #f8f9fa;">
                        <h5 class="card-title text-uppercase text-muted fs-6 mb-3">Amount Due</h5>
                        <h2 class="text-primary mb-0">@invoice.TotalPostTax.ToString("C")</h2>
                        <div class="fs-5 text-muted mt-2">
                            Pre-Tax: @invoice.TotalPreTax.ToString("C")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">VAT %</th>
                            <th class="text-end">VAT Amount</th>
                            <th class="text-end pe-4">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var line in invoice.Lines)
                        {
                            <tr>
                                <td class="ps-4 py-3 fw-medium">@(line.Product?.Name ?? $"Product #{line.ProductId}")</td>
                                <td class="text-center py-3">@line.Quantity</td>
                                <td class="text-end py-3">@line.UnitPricePreTax.ToString("C")</td>
                                <td class="text-end py-3">@line.VatRate.ToString("0.##")%</td>
                                <td class="text-end py-3">@line.SubtotalVat.ToString("C")</td>
                                <td class="text-end pe-4 py-3 fw-bold">@line.SubtotalPostTax.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row pt-3">
            <div class="col-md-5 offset-md-7">
                <div class="card border-0 bg-light">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal (Pre-Tax)</span>
                            <span class="fw-medium">@invoice.TotalPreTax.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Total VAT</span>
                            <span class="fw-medium">@invoice.TotalVat.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="text-muted">Tax Stamp</span>
                            <span class="fw-medium">@invoice.TaxStampAmount.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-dark">Total</span>
                            <span class="fs-4 fw-bold text-primary">@invoice.TotalPostTax.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Invoice? invoice;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        invoice = await InvoiceService.GetByIdAsync(Id);
        isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/invoices");
    }
}